# ============================================================
# MONEY MIND - BPO FINANCEIRO
# Copie este arquivo para .env e preencha os valores locais.
# NUNCA commite o .env real.
# ============================================================

# -------- App --------
NODE_ENV=development
APP_URL=http://localhost:3000
# URL base da API (sem path) — útil para scripts; a web usa NEXT_PUBLIC_API_URL abaixo.
API_URL=http://localhost:3333

# -------- Database (Postgres 16 / Supabase) --------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/money_mind
DATABASE_SSL=false

# -------- Redis (BullMQ) --------
# Opção A: URL única (lida pela API via redis.config)
REDIS_URL=redis://localhost:6379
# Opção B: host/porta (apps/api também aceita REDIS_HOST, REDIS_PORT, REDIS_PASSWORD, REDIS_DB)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# -------- Supabase --------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# -------- Auth / Security --------
# AES-256-GCM: exatamente 64 caracteres hex (32 bytes). Gere com: openssl rand -hex 32
ENCRYPTION_KEY=
# Legado / outros stacks — o backend Nest valida JWT com SUPABASE_JWT_SECRET (acima).
JWT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -------- Frontend (Next.js public vars) --------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Deve incluir o prefixo global da API Nest: /api/v1
NEXT_PUBLIC_API_URL=http://localhost:3333/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -------- Integrações externas (placeholders) --------
TINY_V2_BASE_URL=https://api.tiny.com.br/api2
TINY_V3_BASE_URL=https://api.tiny.com.br/public-api/v3
CONTA_SIMPLES_BASE_URL=https://api.contasimples.com
PAGARME_BASE_URL=https://api.pagar.me/core/v5
VIACEP_BASE_URL=https://viacep.com.br/ws
BRASILAPI_BASE_URL=https://brasilapi.com.br/api

# -------- Observability --------
LOG_LEVEL=info
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -------- E2E Tests (Playwright) --------
E2E_BASE_URL=http://localhost:3000
E2E_EMAIL=test@moneymind.app
E2E_PASSWORD=testpassword123
