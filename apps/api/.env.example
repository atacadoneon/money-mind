# --- API ---
API_PORT=3333
CORS_ORIGIN=http://localhost:3000
TYPEORM_LOGGING=false
NODE_ENV=development

# --- Database (Supabase / Postgres 16) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/money_mind
DATABASE_SSL=false
DATABASE_POOL_MAX=20

# --- Redis (BullMQ) ---
# Opcional: REDIS_URL=redis://:senha@127.0.0.1:6379/0 (sobrescreve HOST/PORT quando definida)
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Supabase Auth ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Crypto ---
# 32 bytes hex. Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info

# --- MCP Bancos ---
SICOOB_BASE_URL=https://sandbox.sicoob.com.br/sicoob/sandbox
ITAU_BASE_URL=https://sandbox.devportal.itau.com.br
BB_BASE_URL=https://api.hm.bb.com.br
CONTA_SIMPLES_BASE_URL=https://sandbox.contasimples.com
TINY_API_URL=https://api.tiny.com.br/api2

# --- MCP Gateways ---
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_WEBHOOK_SECRET=

# --- MCP Comunicacao ---
# WhatsApp (Gupshup)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@moneymind.com.br
SENDGRID_FROM_NAME=Money Mind BPO

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
